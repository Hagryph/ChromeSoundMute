{
  "manifest_version": 3,
  "name": "Chrome SoundMute",
  "version": "0.2.2",
  "description": "Undetectable tab muting via Chrome tab capture.",
  "permissions": ["tabCapture", "offscreen", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle silent tab mute"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.twitch.tv/*",
        "*://player.twitch.tv/*",
        "*://embed.twitch.tv/*",
        "*://m.twitch.tv/*"
      ],
      "js": ["content-twitch.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
