{
  "manifest_version": 3,
  "name": "Chrome SoundMute",
  "version": "0.1.0",
  "description": "Undetectable tab muting via Chrome tab capture.",
  "permissions": ["tabCapture", "offscreen", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle silent tab mute"
  }
}
